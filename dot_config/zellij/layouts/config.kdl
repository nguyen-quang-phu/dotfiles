layout {
  default_tab_template {
    children
    pane size=1 borderless=true {
      plugin location="zellij:compact-bar"
    }
  }

  cwd "~"
  tab name="1. Config neovim" focus=true cwd=".config/nvim/" {
    pane command="nvim" borderless=true{
      args "init.lua"
    }
  }

  tab name="2. Config zellij" cwd=".config/zellij/" {
    pane command="nvim" borderless=true{
      args "config.kdl"
    }
  }

  tab name="3. Terminal" cwd=".config/" {
    pane name="Terminal"
  }
}
