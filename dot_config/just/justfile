default:
  just -g --list

[group('hyprland')]
hypr-reload:
  hyprctl reload

[group('ssh')]
keygen email:
  ssh-keygen -t rsa -C {{email}}

[group('archlinux')]
arch-install pkg:
  if pacman -Si {{pkg}} >/dev/null 2>&1; then \
    sudo pacman -S --noconfirm {{pkg}}; \
  elif yay -Si {{pkg}}-bin >/dev/null 2>&1; then \
    yay -S --noconfirm {{pkg}}-bin; \
  elif yay -Si {{pkg}}-git >/dev/null 2>&1; then \
    yay -S --noconfirm {{pkg}}-git; \
  else \
    yay -S --noconfirm {{pkg}}; \
  fi \

[group('brew')]
[group('pacman')]
install +args:
  {{
    if os() =~ 'linux' { 
      'just -g arch-install'
    } else if os() =~ 'macos' { 
      'brew install' 
    } else { 
      error('unsupported OS') 
    }
  }} {{args}}

[group('git')]
[no-cd]
worktree-window branch:
  #!/usr/bin/env bash
  set -euo pipefail
  [[ -n "${TMUX:-}" ]] || { echo "❌ Not inside a tmux session — start tmux first."; exit 1; }
  branch="{{branch}}"

  # Locate the branch's existing worktree (empty if none yet).
  find_worktree() {
    git worktree list --porcelain \
      | awk -v b="refs/heads/${branch}" '/^worktree /{p=$2} $0=="branch "b{print p}'
  }

  wt_path="$(find_worktree)"
  if [[ -z "$wt_path" ]]; then
    echo "🌱 Creating worktree for ${branch} via Worktrunk..."
    wt switch "$branch" --yes --no-cd
    wt_path="$(find_worktree)"
  fi
  [[ -n "$wt_path" ]] || { echo "❌ Could not locate worktree for ${branch}"; exit 1; }

  # Short tab name:
  #   release branch (pre-release/…-0.34.0)  → release-0.34.0
  #   ticket branch  (feature/wo-1068-foo)   → WO-1068
  #   otherwise                              → last path segment
  seg="${branch##*/}"
  if [[ "$branch" == *release/* && "$seg" =~ ([0-9]+\.[0-9]+\.[0-9]+) ]]; then
    window="release-${BASH_REMATCH[1]}"
  elif [[ "$seg" =~ ^([a-zA-Z]+-[0-9]+) ]]; then
    window="$(echo "${BASH_REMATCH[1]}" | tr '[:lower:]' '[:upper:]')"
  else
    window="$seg"
  fi
  echo "🪟 Opening tmux window '${window}' → ${wt_path}"
  tmux new-window -c "$wt_path" -n "$window"

[group('doom-emacs')]
doom-sync:
  chezmoi apply ~/.config/doom/ && ~/.config/emacs/bin/doom sync

[group('orgmode')]
sync-orgmode message="sync":
  chezmoi re-add --re-encrypt ~/org
  git -C "$(chezmoi source-path)" add org/
  @if git -C "$(chezmoi source-path)" diff --staged --quiet; then \
    echo "No changes to commit"; \
  else \
    git -C "$(chezmoi source-path)" commit -m "chore(org): {{message}} $(date +'%Y-%m-%d %H:%M:%S')"; \
  fi
