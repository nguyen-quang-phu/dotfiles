function brew() {
  echo "brew $@"
  command brew $@
  echo "brew bundle dump --file=~/Brewfile -f"
  command brew bundle dump --file=~/Brewfile -f
  echo "chezmoi add ~/Brewfile"
  command chezmoi add ~/Brewfile
  echo "DONE"
}

function source() {
  $(command source $@)
  echo "source $@"
  if [[  $1 == '/Users/harvey/.zshrc' ]];
  then
      echo "chezmoi re-add"
      command chezmoi re-add
  fi
}
